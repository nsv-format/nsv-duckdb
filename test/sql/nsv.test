# name: test/sql/nsv.test
# description: Test NSV extension — read_nsv and COPY TO
# group: [sql]

require nsv

# ── read_nsv: type narrowing ────────────────────────────────────────

# Create a test file with mixed types using CSV as a writer trick
statement ok
COPY (SELECT * FROM (VALUES ('name'),('age'),('salary'),('active'),(''),('Alice'),('30'),('50000.50'),('true'),(''),('Bob'),('25'),('75000.25'),('false'),(''))) TO '__TEST_DIR__/types.nsv' (FORMAT CSV, HEADER false, QUOTE '');

# Types should be auto-detected
query IIII
SELECT typeof(name), typeof(age), typeof(salary), typeof(active) FROM read_nsv('__TEST_DIR__/types.nsv') LIMIT 1;
----
VARCHAR	BIGINT	DOUBLE	BOOLEAN

# Values should parse correctly
query ITRI
SELECT name, age, salary, active FROM read_nsv('__TEST_DIR__/types.nsv');
----
Alice	30	50000.5	true
Bob	25	75000.25	false

# ── read_nsv: all_varchar ───────────────────────────────────────────

query IIII
SELECT typeof(name), typeof(age), typeof(salary), typeof(active) FROM read_nsv('__TEST_DIR__/types.nsv', all_varchar=true) LIMIT 1;
----
VARCHAR	VARCHAR	VARCHAR	VARCHAR

query TTTT
SELECT name, age, salary, active FROM read_nsv('__TEST_DIR__/types.nsv', all_varchar=true);
----
Alice	30	50000.50	true
Bob	25	75000.25	false

# ── read_nsv: pure strings ──────────────────────────────────────────

statement ok
COPY (SELECT * FROM (VALUES ('city'),('country'),(''),('NYC'),('USA'),(''),('London'),('UK'),(''))) TO '__TEST_DIR__/strings.nsv' (FORMAT CSV, HEADER false, QUOTE '');

query II
SELECT typeof(city), typeof(country) FROM read_nsv('__TEST_DIR__/strings.nsv') LIMIT 1;
----
VARCHAR	VARCHAR

query TT
SELECT * FROM read_nsv('__TEST_DIR__/strings.nsv');
----
NYC	USA
London	UK

# ── read_nsv: aggregations on narrowed types ────────────────────────

query I
SELECT SUM(age) FROM read_nsv('__TEST_DIR__/types.nsv');
----
55

query R
SELECT SUM(salary) FROM read_nsv('__TEST_DIR__/types.nsv');
----
125000.75

# ── read_nsv: boolean filtering ─────────────────────────────────────

query T
SELECT name FROM read_nsv('__TEST_DIR__/types.nsv') WHERE active = true;
----
Alice

# ── COPY TO nsv: roundtrip ──────────────────────────────────────────

# Write a table out as NSV
statement ok
CREATE TABLE roundtrip_src AS SELECT * FROM read_nsv('__TEST_DIR__/types.nsv');

statement ok
COPY roundtrip_src TO '__TEST_DIR__/roundtrip.nsv' (FORMAT nsv);

# Read it back — should match
query ITRI
SELECT name, age, salary, active FROM read_nsv('__TEST_DIR__/roundtrip.nsv');
----
Alice	30	50000.5	true
Bob	25	75000.25	false

# ── COPY TO nsv: types preserved through roundtrip ──────────────────

query IIII
SELECT typeof(name), typeof(age), typeof(salary), typeof(active) FROM read_nsv('__TEST_DIR__/roundtrip.nsv') LIMIT 1;
----
VARCHAR	BIGINT	DOUBLE	BOOLEAN

# ── read_nsv: column projection ───────────────────────────────────

# Single column projection
query T
SELECT name FROM read_nsv('__TEST_DIR__/types.nsv');
----
Alice
Bob

# Non-first column projection
query R
SELECT salary FROM read_nsv('__TEST_DIR__/types.nsv');
----
50000.5
75000.25

# Two non-adjacent columns
query TR
SELECT name, salary FROM read_nsv('__TEST_DIR__/types.nsv');
----
Alice	50000.5
Bob	75000.25

# Reversed column order
query RT
SELECT salary, name FROM read_nsv('__TEST_DIR__/types.nsv');
----
50000.5	Alice
75000.25	Bob

# Aggregation on projected column
query I
SELECT SUM(age) FROM read_nsv('__TEST_DIR__/types.nsv');
----
55

# Full permutation — all columns, different order (hits eager fallback path)
query IRIT
SELECT active, salary, age, name FROM read_nsv('__TEST_DIR__/types.nsv');
----
true	50000.5	30	Alice
false	75000.25	25	Bob

# Count with projection
query I
SELECT COUNT(*) FROM read_nsv('__TEST_DIR__/types.nsv') WHERE active = false;
----
1

# ── Filter pushdown ──────────────────────────────────────────────────

# Create a larger dataset for filter testing
statement ok
COPY (SELECT * FROM (VALUES ('id'),('name'),('age'),('city'),('score'),(''),('1'),('Alice'),('30'),('NYC'),('85.5'),(''),('2'),('Bob'),('25'),('London'),('92.0'),(''),('3'),('Carol'),('35'),('NYC'),('78.3'),(''),('4'),('Dave'),('28'),('Paris'),('95.1'),(''),('5'),('Eve'),('30'),('London'),('88.7'),(''))) TO '__TEST_DIR__/filter.nsv' (FORMAT CSV, HEADER false, QUOTE '');

# Equality filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age = 30;
----
Alice	30
Eve	30

# Greater-than filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age > 28;
----
Alice	30
Carol	35
Eve	30

# Less-than filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age < 28;
----
Bob	25

# Greater-or-equal filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age >= 30;
----
Alice	30
Carol	35
Eve	30

# Less-or-equal filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age <= 25;
----
Bob	25

# Range filter (AND of two comparisons on same column)
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age >= 28 AND age <= 30;
----
Alice	30
Dave	28
Eve	30

# VARCHAR equality filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE city = 'NYC';
----
Alice	30
Carol	35

# DOUBLE comparison filter
query TR
SELECT name, score FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE score > 90.0;
----
Bob	92.0
Dave	95.1

# IN filter
query TI
SELECT name, age FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE city IN ('NYC', 'Paris');
----
Alice	30
Carol	35
Dave	28

# Filter on column not in SELECT (filter-only column)
query T
SELECT name FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age > 30;
----
Carol

# Filter + projection combined
query R
SELECT score FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE city = 'London' AND age < 30;
----
92.0

# Multiple filters on different columns
query T
SELECT name FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age >= 28 AND city = 'London';
----
Eve

# Count with filter pushdown
query I
SELECT COUNT(*) FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE age > 25;
----
4

# Aggregation with filter pushdown
query R
SELECT AVG(score) FROM read_nsv('__TEST_DIR__/filter.nsv') WHERE city = 'NYC';
----
81.9

# ── Filter pushdown: NULL handling ───────────────────────────────────

# Create a file with some NULL cells using COPY TO nsv
statement ok
CREATE TABLE nulls_src(key VARCHAR, val BIGINT);

statement ok
INSERT INTO nulls_src VALUES ('a', 10), ('b', NULL), ('c', 30);

statement ok
COPY nulls_src TO '__TEST_DIR__/nulls.nsv' (FORMAT nsv);

statement ok
DROP TABLE nulls_src;

# IS NOT NULL filter
query TI
SELECT key, val FROM read_nsv('__TEST_DIR__/nulls.nsv') WHERE val IS NOT NULL;
----
a	10
c	30

# IS NULL filter
query T
SELECT key FROM read_nsv('__TEST_DIR__/nulls.nsv') WHERE val IS NULL;
----
b
