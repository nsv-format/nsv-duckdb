# ── NSV-specific: sample boundary ─────────────────────────────────
# DetectColumnType samples rows 1..min(nrows, 1001) = first 1000 data rows.
# Row 1001 is beyond the sample window. If it doesn't match the inferred
# type, it silently becomes NULL at scan time.
# This is NSV-specific (CSV sniffer has its own sample logic).

statement ok
CREATE TABLE boundary_src(num VARCHAR);

statement ok
INSERT INTO boundary_src SELECT i::VARCHAR FROM range(1, 1001) t(i);

statement ok
INSERT INTO boundary_src VALUES ('not_a_number');

statement ok
INSERT INTO boundary_src VALUES ('42');

statement ok
COPY boundary_src TO '__TEST_DIR__/boundary.nsv' (FORMAT nsv);

statement ok
DROP TABLE boundary_src;

# Should narrow to numeric type (first 1000 rows are all integers)
query B
SELECT typeof(num) != 'VARCHAR' FROM read_nsv('__TEST_DIR__/boundary.nsv') LIMIT 1;
----
true

# Row 1001 ("not_a_number") fails cast → NULL
query I
SELECT num FROM read_nsv('__TEST_DIR__/boundary.nsv') WHERE num IS NULL;
----
NULL

# Total row count
query I
SELECT COUNT(*) FROM read_nsv('__TEST_DIR__/boundary.nsv');
----
1002

# Last row (after the bad one) still works
query I
SELECT num FROM read_nsv('__TEST_DIR__/boundary.nsv') OFFSET 1001;
----
42

# ── Large table roundtrip ─────────────────────────────────────────

statement ok
CREATE TABLE large_src AS SELECT i AS id, 'name_' || i::VARCHAR AS name, (i * 1.5)::DOUBLE AS value FROM range(1, 1001) t(i);

statement ok
COPY large_src TO '__TEST_DIR__/large.csv' (FORMAT CSV);

statement ok
COPY large_src TO '__TEST_DIR__/large.nsv' (FORMAT nsv);

statement ok
DROP TABLE large_src;

# Row count parity
query B
SELECT (SELECT COUNT(*) FROM read_csv('__TEST_DIR__/large.csv')) =
       (SELECT COUNT(*) FROM read_nsv('__TEST_DIR__/large.nsv'));
----
true

# Aggregation parity
query B
SELECT (SELECT SUM(id) FROM read_csv('__TEST_DIR__/large.csv')) =
       (SELECT SUM(id) FROM read_nsv('__TEST_DIR__/large.nsv'));
----
true

# Spot check first row
query B
SELECT bool_and(
  csv.id IS NOT DISTINCT FROM nsv.id AND
  csv.name IS NOT DISTINCT FROM nsv.name AND
  csv.value IS NOT DISTINCT FROM nsv.value
)
FROM (SELECT * FROM read_csv('__TEST_DIR__/large.csv') LIMIT 1) csv
POSITIONAL JOIN (SELECT * FROM read_nsv('__TEST_DIR__/large.nsv') LIMIT 1) nsv;
----
true
