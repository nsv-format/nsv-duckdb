# ── NULL handling ──────────────────────────────────────────────────

# NULLs in multi-column data
statement ok
CREATE TABLE with_nulls(name VARCHAR, age VARCHAR);

statement ok
INSERT INTO with_nulls VALUES ('Alice', '30'), (NULL, NULL), ('Bob', '25');

statement ok
COPY with_nulls TO '__TEST_DIR__/with_nulls.csv' (FORMAT CSV);

statement ok
COPY with_nulls TO '__TEST_DIR__/with_nulls.nsv' (FORMAT nsv);

statement ok
DROP TABLE with_nulls;

# Type parity for both columns
query BB
SELECT (SELECT typeof(name) FROM read_csv('__TEST_DIR__/with_nulls.csv') LIMIT 1) =
       (SELECT typeof(name) FROM read_nsv('__TEST_DIR__/with_nulls.nsv') LIMIT 1),
       (SELECT typeof(age) FROM read_csv('__TEST_DIR__/with_nulls.csv') LIMIT 1) =
       (SELECT typeof(age) FROM read_nsv('__TEST_DIR__/with_nulls.nsv') LIMIT 1);
----
true	true

# Value parity
query B
SELECT bool_and(
  csv.name IS NOT DISTINCT FROM nsv.name AND
  csv.age IS NOT DISTINCT FROM nsv.age
)
FROM read_csv('__TEST_DIR__/with_nulls.csv') csv
POSITIONAL JOIN read_nsv('__TEST_DIR__/with_nulls.nsv') nsv;
----
true

# NULL count parity
query B
SELECT (SELECT COUNT(*) FROM read_csv('__TEST_DIR__/with_nulls.csv') WHERE name IS NULL) =
       (SELECT COUNT(*) FROM read_nsv('__TEST_DIR__/with_nulls.nsv') WHERE name IS NULL);
----
true

# NULLs don't break type narrowing — age column still narrows despite NULL row
query B
SELECT (SELECT typeof(age) FROM read_nsv('__TEST_DIR__/with_nulls.nsv') LIMIT 1) != 'VARCHAR';
----
true

# ── Multi-type roundtrip ──────────────────────────────────────────

# Multiple columns of different types through both formats
statement ok
CREATE TABLE multi_type AS SELECT * FROM (VALUES
  (1, 'hello', 3.14, true, DATE '2026-01-01', TIMESTAMP '2026-01-01 12:00:00'),
  (2, 'world', 2.71, false, DATE '2026-02-15', TIMESTAMP '2026-02-15 08:30:00')
) t(id, name, value, flag, d, ts);

statement ok
COPY multi_type TO '__TEST_DIR__/multi_type.csv' (FORMAT CSV);

statement ok
COPY multi_type TO '__TEST_DIR__/multi_type.nsv' (FORMAT nsv);

statement ok
DROP TABLE multi_type;

# Type parity across all columns
query BBBBBB
SELECT (SELECT typeof(id) FROM read_csv('__TEST_DIR__/multi_type.csv') LIMIT 1) =
       (SELECT typeof(id) FROM read_nsv('__TEST_DIR__/multi_type.nsv') LIMIT 1),
       (SELECT typeof(name) FROM read_csv('__TEST_DIR__/multi_type.csv') LIMIT 1) =
       (SELECT typeof(name) FROM read_nsv('__TEST_DIR__/multi_type.nsv') LIMIT 1),
       (SELECT typeof(value) FROM read_csv('__TEST_DIR__/multi_type.csv') LIMIT 1) =
       (SELECT typeof(value) FROM read_nsv('__TEST_DIR__/multi_type.nsv') LIMIT 1),
       (SELECT typeof(flag) FROM read_csv('__TEST_DIR__/multi_type.csv') LIMIT 1) =
       (SELECT typeof(flag) FROM read_nsv('__TEST_DIR__/multi_type.nsv') LIMIT 1),
       (SELECT typeof(d) FROM read_csv('__TEST_DIR__/multi_type.csv') LIMIT 1) =
       (SELECT typeof(d) FROM read_nsv('__TEST_DIR__/multi_type.nsv') LIMIT 1),
       (SELECT typeof(ts) FROM read_csv('__TEST_DIR__/multi_type.csv') LIMIT 1) =
       (SELECT typeof(ts) FROM read_nsv('__TEST_DIR__/multi_type.nsv') LIMIT 1);
----
true	true	true	true	true	true

# Value parity across all columns
query B
SELECT bool_and(
  csv.id IS NOT DISTINCT FROM nsv.id AND
  csv.name IS NOT DISTINCT FROM nsv.name AND
  csv.value IS NOT DISTINCT FROM nsv.value AND
  csv.flag IS NOT DISTINCT FROM nsv.flag AND
  csv.d IS NOT DISTINCT FROM nsv.d AND
  csv.ts IS NOT DISTINCT FROM nsv.ts
)
FROM read_csv('__TEST_DIR__/multi_type.csv') csv
POSITIONAL JOIN read_nsv('__TEST_DIR__/multi_type.nsv') nsv;
----
true

