# name: test/sql/nsv_type_narrowing.test
# description: Verify NSV type narrowing matches CSV for the same data
# group: [sql]

require nsv

# ── Integer narrowing ─────────────────────────────────────────────

# Small integers
statement ok
CREATE TABLE small_ints(num VARCHAR);

statement ok
INSERT INTO small_ints VALUES ('1'), ('2'), ('3');

statement ok
COPY small_ints TO '__TEST_DIR__/small_ints.csv' (FORMAT CSV);

statement ok
COPY small_ints TO '__TEST_DIR__/small_ints.nsv' (FORMAT nsv);

statement ok
DROP TABLE small_ints;

query B
SELECT (SELECT typeof(num) FROM read_csv('__TEST_DIR__/small_ints.csv') LIMIT 1) =
       (SELECT typeof(num) FROM read_nsv('__TEST_DIR__/small_ints.nsv') LIMIT 1);
----
true

query B
SELECT bool_and(csv.num IS NOT DISTINCT FROM nsv.num)
FROM read_csv('__TEST_DIR__/small_ints.csv') csv
POSITIONAL JOIN read_nsv('__TEST_DIR__/small_ints.nsv') nsv;
----
true

